{
  "name": "kira-kira",
  "version": "0.1.0",
  "private": true,
  "description": "Malaysian kopitiam-themed split bill tracker for the Krackeddevs bounty",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev --port 8787",
    "build": "next build",
    "preview": "opennextjs-cloudflare build && wrangler dev --port 8787",
    "deploy": "opennextjs-cloudflare build && wrangler deploy",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:apply:local": "wrangler d1 migrations apply kira-kira-db --local",
    "db:apply:remote": "wrangler d1 migrations apply kira-kira-db --remote",
    "test": "vitest"
  },
  "dependencies": {
    "@base-ui/react": "1.5.0",
    "@opennextjs/cloudflare": "1.19.11",
    "canvas-confetti": "1.9.4",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "drizzle-orm": "0.45.2",
    "lucide-react": "1.16.0",
    "nanoid": "5.1.11",
    "next": "16.2.6",
    "next-themes": "0.4.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "sonner": "2.0.7",
    "swr": "2.4.1",
    "tailwind-merge": "3.6.0",
    "tw-animate-css": "1.4.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@libsql/client": "0.17.3",
    "@tailwindcss/postcss": "4.3.0",
    "@types/canvas-confetti": "1.9.0",
    "@types/node": "25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "4.1.7",
    "drizzle-kit": "0.31.10",
    "eslint": "10.4.0",
    "eslint-config-next": "16.2.6",
    "postcss": "8.5.15",
    "shadcn": "4.8.0",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3",
    "vitest": "4.1.7",
    "wrangler": "4.94.0"
  }
}
